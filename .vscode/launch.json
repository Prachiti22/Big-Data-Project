{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Download dataset",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/data/download_data.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Run full pipeline",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/run_pipeline.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "justMyCode": false
    },
    {
      "name": "Debug current file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" },
      "justMyCode": false
    }
  ]
}
